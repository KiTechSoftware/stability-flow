{
    "name": "Stability Flow - hotfix branches",
    "target": "branch",
    "enforcement": "active",
    "conditions": {
      "ref_name": {
        "include": ["refs/heads/hotfix/*"],
        "exclude": []
      }
    },
    "rules": [
      { "type": "deletion" },
      { "type": "non_fast_forward" },
      {
        "type": "required_status_checks",
        "parameters": {
          "strict_required_status_checks_policy": true,
          "required_status_checks": [
            { "context": "stability-flow/hotfix-branch" }
          ]
        }
      }
    ],
    "bypass_actors": []
  }